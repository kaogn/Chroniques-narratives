# Human Memories - Environment Variables Template
# Copy to .env and fill with your actual values

# Application
ENVIRONMENT=development
DEBUG=true
APP_NAME="Human Memories API"
APP_VERSION="1.0.0"

# Security (Generate a strong 32+ character secret key)
SECRET_KEY=your-super-secret-key-here-min-32-chars
ALGORITHM=HS256

# Database (Railway will provide these automatically)
DATABASE_URL=postgresql://username:password@host:port/database
POSTGRES_DB=human_memories
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS & Security
CORS_ORIGINS=["http://localhost:3000","https://your-frontend-domain.vercel.app"]
ALLOWED_HOSTS=["localhost","127.0.0.1","your-api-domain.railway.app"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Logging & Monitoring
LOG_LEVEL=INFO
SENTRY_DSN=your-sentry-dsn-here

# Optional: Redis for caching
REDIS_URL=redis://localhost:6379/0